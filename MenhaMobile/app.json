{
  "expo": {
    "name": "MenhaMobile",
    "slug": "menhamobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.menhaboutique.mobile",
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.menhaboutique.mobile",
          "enableGooglePay": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://phonepe.mycloudrepo.io/public/repositories/phonepe-intentsdk-android"
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ab57f212-815f-409b-83bf-43f7225794f2"
      }
    }
  }
}
